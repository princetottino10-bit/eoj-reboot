rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAllowedUser() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/allowed_users/$(request.auth.token.email));
    }

    match /rooms/{roomId} {
      // 参加済みの参加者か（作成者 or 参加者）
      function isParticipant() {
        return request.auth.uid == resource.data.createdBy
            || (resource.data.joinedBy != null && request.auth.uid == resource.data.joinedBy);
      }

      // 参加者が変更してはならない識別フィールドが不変であることを保証
      function participantFieldsImmutable() {
        return request.resource.data.createdBy == resource.data.createdBy
            && request.resource.data.joinedBy  == resource.data.joinedBy
            && request.resource.data.createdAt == resource.data.createdAt;
      }

      // 空きルームへの参加操作
      // 変更可能なのは joinedBy（自分の uid）と phase（'draft' 固定）のみ
      function isJoining() {
        return resource.data.joinedBy == null
            && request.resource.data.joinedBy  == request.auth.uid
            && request.resource.data.createdBy == resource.data.createdBy
            && request.resource.data.phase     == 'draft'
            && request.resource.data.gameState == resource.data.gameState
            && request.resource.data.draftUi   == resource.data.draftUi
            && request.resource.data.createdAt == resource.data.createdAt;
      }

      // 未参加のルームも読める（参加トランザクション内の get に必要）
      allow read: if isAllowedUser() && (isParticipant() || resource.data.joinedBy == null);

      // 作成: createdBy を自分の uid に、joinedBy は null のみ許可
      allow create: if isAllowedUser()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.joinedBy  == null;

      // 更新: 参加者は識別フィールド不変の条件下で可、または参加操作のみ
      allow update: if isAllowedUser() && (
        (isParticipant() && participantFieldsImmutable())
        || isJoining()
      );

      allow delete: if false;
    }

    // 自分のメールアドレスのドキュメントのみ読み取り可（招待確認用）
    // 書き込みは Firebase Console からのみ（管理者が手動で招待）
    match /allowed_users/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }
  }
}
