{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EOJ Reboot Card Data",
  "type": "object",
  "required": ["keyword_effects", "characters", "items"],
  "additionalProperties": false,
  "properties": {
    "keyword_effects": {
      "type": "object",
      "description": "Keyword name → short effect description for card rendering.",
      "additionalProperties": { "type": "string" }
    },
    "characters": {
      "type": "array",
      "items": { "$ref": "#/definitions/Character" }
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/definitions/Item" }
    }
  },
  "definitions": {
    "Coord": {
      "type": "array",
      "description": "[row, col] relative to character. row: front=positive, back=negative. col: right=positive, left=negative.",
      "items": { "type": "integer" },
      "minItems": 2,
      "maxItems": 2
    },
    "Character": {
      "type": "object",
      "required": ["id", "name", "faction", "cost", "vp", "hp", "atk", "reactivation_cost", "attribute", "attack_cells", "attack_type", "keywords", "effect", "ult"],
      "additionalProperties": false,
      "properties": {
        "id":               { "type": "string", "pattern": "^[a-z_]+_v2_[0-9]{2}$" },
        "name":             { "type": "string" },
        "faction":          { "type": "string", "enum": ["aggro", "tank", "control", "synergy", "snipe", "trick"] },
        "cost":             { "type": "integer", "minimum": 0 },
        "vp":               { "type": "integer", "minimum": 1 },
        "hp":               { "type": "integer", "minimum": 1 },
        "atk":              { "type": "integer", "minimum": 0 },
        "reactivation_cost":{ "type": "integer", "minimum": 1 },
        "attribute":        { "type": "string", "enum": ["拳", "念", "光", "闇", "虚"] },
        "attack_cells": {
          "description": "Cells this character can attack. \"all\" = 全域, null = cannot attack, array = specific relative coords.",
          "oneOf": [
            { "type": "string", "enum": ["all"] },
            { "type": "null" },
            {
              "type": "array",
              "items": { "$ref": "#/definitions/Coord" },
              "minItems": 1
            }
          ]
        },
        "weakness_cells": {
          "description": "Cells from which attackers gain B-position bonus. Defaults to [[-1,0]] (directly behind) when omitted.",
          "type": "array",
          "items": { "$ref": "#/definitions/Coord" }
        },
        "attack_type":  { "type": "string", "enum": ["物理", "魔法"] },
        "keywords": {
          "type": "array",
          "items": { "type": "string", "enum": ["先制", "防護", "不動", "カバー", "要塞", "回避", "貫通"] }
        },
        "effect": { "type": "string" },
        "ult": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/definitions/Ult" }
          ]
        }
      }
    },
    "Ult": {
      "type": "object",
      "required": ["name", "vp_cost", "timing", "effect"],
      "additionalProperties": false,
      "properties": {
        "name":     { "type": "string" },
        "vp_cost":  { "type": "integer", "minimum": 1 },
        "timing":   { "type": "string", "enum": ["次ターン以降", "召喚ターン可"] },
        "effect":   { "type": "string" }
      }
    },
    "Item": {
      "type": "object",
      "required": ["id", "name", "cost", "vp", "effect", "sets"],
      "additionalProperties": false,
      "properties": {
        "id":     { "type": "string" },
        "name":   { "type": "string" },
        "cost":   { "type": "integer", "minimum": 0 },
        "vp":     { "type": "integer", "minimum": 1 },
        "effect": { "type": "string" },
        "sets": {
          "type": "array",
          "items": { "type": "string", "enum": ["A", "B", "C", "D"] },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  }
}
